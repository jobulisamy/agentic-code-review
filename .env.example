# Agentic Code Review — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Backend database (SQLite path inside Docker container — do not change for local dev)
DATABASE_URL=sqlite+aiosqlite:////app/data/reviews.db

# LLM provider — "groq" (default, free) or "claude"
LLM_PROVIDER=groq

# Groq API key — required when LLM_PROVIDER=groq
# Get from: https://console.groq.com/keys
GROQ_API_KEY=REPLACE_ME

# Anthropic API key — required when LLM_PROVIDER=claude
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=REPLACE_ME

# GitHub webhook secret — required for Phase 4 (GitHub integration)
# Set this when creating the GitHub App webhook
GITHUB_WEBHOOK_SECRET=REPLACE_ME

# SQLAlchemy query logging — set to true for debugging DB queries
DB_ECHO=false
